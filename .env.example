# Скопируй в .env на сервере и заполни реальными значениями.
# Файл .env не должен попасть в git.

# --- Postgres ---
POSTGRES_DB=vsmatch
POSTGRES_USER=vsmatch
# Сгенерируй случайный: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME

# --- JWT ---
JWT_ISSUER=vsmatch
JWT_AUDIENCE=vsmatch
# 32+ байт случайных: openssl rand -base64 48
JWT_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# --- VK ID ---
VKID_CLIENT_ID=54461863
VKID_CLIENT_SECRET=AdBCXHet2KC5U7yCJOBV
VKID_REDIRECT_URI=https://vsmatch.ru/api/auth/vkid/callback
VKID_FRONTEND_REDIRECT_URL=https://vsmatch.ru/auth/callback
